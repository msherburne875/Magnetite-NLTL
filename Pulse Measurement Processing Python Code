def signalProcessing ( filePath , time_window = None ):
’’’
The goal of this function is to capture the main parameters of
the recorded signal , including parameters such as Record
Length , Sample Interval , Trigger Point , Trigger Time ,
Horizontal Offset and FastFrame Count , reported by default in
the Tektronix DPO 71254 C Oscilloscope . This information is
stored in the dictionary Parameters Then , the time and
amplitude vectors are separated in two different dataframes (
time and amplitude ), where each column stores the amplitude
and time vectors for each shot . Subsequently , the amplitude
is compensated to represent the actual signal .
Then , the waveform is splitted at the maximum amplitude and the
left segment is used to determine the time at 10% and 90% of
the amplitude , after the DC offset is removed from the signal
. This is the input for the calculate_risetime function .
Finally , the spectral content of the time domain signal is
calculated through the welch function , where the sampling
frequency is set to 1ts and the number of samples per segment
is 128. The spectrum and frequency information is stored in
the dictionary spectrum .
The function returns the dictionary parameters and spectrum , as
well as the dataframes amplitude , time , and risetime .
’’’
data = pd. read_csv ( filePath , header = None , low_memory = False )
parameters = {
" Record ␣ Length ": int( data . iloc [0, 1]) ,
" Sample ␣ Interval ": float ( data . iloc [1, 1]) ,
" Trigger ␣ Point ": int( data . iloc [2, 1]) ,
" Trigger ␣ Time ": float ( data . iloc [3, 1]) ,
" Horizontal ␣ Offset ": float ( data . iloc [5, 1]) ,
" FastFrame ␣ Count ": int( data . iloc [6, 1])
}
time = pd. DataFrame ( data . iloc [:, 3]. values . reshape ( parameters ["
FastFrame ␣ Count "], parameters [" Record ␣ Length "]).T)
amplitude = pd. DataFrame ( data . iloc [:, 4]. values . reshape (
parameters [" FastFrame ␣ Count "], parameters [" Record ␣ Length "]).T
)
if ’Ch1 ’ in filePath :
amplitude = pd. DataFrame ( cumulative_trapezoid ( amplitude - np.
mean ( amplitude ), time , dx = parameters [" Sample ␣ Interval "],
axis =0, initial = 0) *76128047281274.601152913377134275)
elif ’Ch2 ’ in filePath :
amplitude = pd. DataFrame ( amplitude . values *3981)
if time_window :
start_time , end_time = time_window
mask = ( time >= start_time ) & ( time <= end_time )
time = time [ mask ]
amplitude = amplitude [ mask ]
time . dropna ( inplace = True )
amplitude . dropna ( inplace = True )
time = time . reset_index ( drop = True )
amplitude = amplitude . reset_index ( drop = True )
for column in amplitude . columns :
start_idx = np. where ( amplitude [ column ] >= 1 * np.max( amplitude
[ column ])) [0][0]
time [ column ] = time [ column ] - time [ column ][ start_idx ]
riseTime = [ calculate_risetime ( amplitude [i], time [i]) for i in
range ( parameters [" FastFrame ␣ Count "])]
spectrum = {}
spectrum [" freqs " ]=[]
spectrum ["psd" ]=[]
for i in range ( amplitude . shape [1]) :
x = amplitude . iloc [:, i]. to_numpy ()
freqs , psd = welch (x, fs =1.0/ parameters [" Sample ␣ Interval "],
nperseg =128)
spectrum [" freqs "]. append ( freqs )
spectrum ["psd"]. append (10 * np. log10 (psd))
return {
" parameters ": parameters ,
" amplitude ": amplitude ,
" time ": time ,
" riseTime ": riseTime ,
" spectrum ": spectrum
}
def calculate_risetime (signal , time_vector ):
’’’
This function takes the left segment of every signal ( amplitude
and time vectors ) and then applies a linear interpolation .
Subsequently , it reconstructs the time vector for the new
dataset and then obtains the difference between the points
with the closest amplitudes to 10% and 90%. The function
returns the risetime for each input group .
’’’
max_idx = np. argmax ( signal )
signal = signal [: max_idx + 1]
time_vector = time_vector [: max_idx + 1]
signal = signal - np. min ( signal )
interp_factor = 20
num_interp_points = len( time_vector ) * interp_factor
new_time_grid = np. linspace ( time_vector .min () , time_vector .max ()
, num= num_interp_points )
interp_func = interp1d ( time_vector , signal , kind =’linear ’,
fill_value =" extrapolate ")
interpolated_signal = interp_func ( new_time_grid )
max_value = np.max( interpolated_signal )
start_idx = np. where ( interpolated_signal <= 0.1 * max_value )
[0][ -1]
end_idx = np. where ( interpolated_signal >= 0.9 * max_value ) [0][0]
return new_time_grid [ end_idx ] - new_time_grid [ start_idx ]
