# Function that converts db/ degrees to regular numbers - instead of
rfparam in matlab makes into insensity of suspetibilty ,
def Conversion (Mag , Angle ):
r = np. power (10 , (Mag /20) ) #S21 Mag
x = np. multiply (r, (np.cos(np. radians ( Angle )))) #S21 Angle - x =
r*cos( degrees )
y = np. multiply (r, (np.sin(np. radians ( Angle )))) #S21 Angle - y =
r*sin( degrees )
y = y * 1j
return x + y
